amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

// pre-commit auto-fixes formatting and lint on staged Rust files and re-stages
// the results. cargo fmt / clippy operate on the whole workspace (they have no
// reliable per-file mode), so the glob only triggers the step when *.rs changes.
hooks {
    ["pre-commit"] {
        fix = true
        stage = true
        steps {
            ["cargo-fmt"] {
                glob = "*.rs"
                fix = "cargo fmt"
            }
            ["cargo-clippy"] {
                glob = "*.rs"
                fix = "cargo clippy --fix --allow-dirty --allow-staged"
            }
        }
    }
    // pre-push is the final gate: check-only formatting/lint plus the full test
    // suite and a coverage report before code reaches the remote.
    ["pre-push"] {
        steps {
            ["cargo-fmt-check"] {
                glob = "*.rs"
                check = "cargo fmt -- --check"
            }
            ["cargo-clippy-check"] {
                glob = "*.rs"
                check = "cargo clippy --all-targets -- -D warnings"
            }
            ["cargo-test"] {
                check = "cargo test"
            }
            ["coverage"] {
                check = "mise run coverage"
            }
        }
    }
}

amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

// pre-commit auto-fixes formatting and lint on staged Rust files and re-stages
// the results. cargo fmt / clippy operate on the whole workspace (they have no
// reliable per-file mode), so the glob only triggers the step when *.rs changes.
hooks {
    // Validate the commit message against Conventional Commits with convco.
    // The step delegates to scripts/lint-commit-msg.sh so it can exempt
    // merge/revert-in-progress commits (git's default messages aren't
    // conventional and must not block conflict resolution).
    ["commit-msg"] {
        steps {
            ["convco"] {
                check = "sh scripts/lint-commit-msg.sh {{commit_msg_file}}"
            }
        }
    }
    ["pre-commit"] {
        fix = true
        stage = true
        steps {
            ["cargo-fmt"] {
                glob = "**/*.rs"
                // Delegates to mise so the pinned nightly (rust-nightly.txt) stays in
                // one place; rustfmt.toml enables unstable import options.
                fix = "mise run format"
            }
            ["cargo-clippy"] {
                glob = "**/*.rs"
                fix = "cargo clippy --fix --allow-dirty --allow-staged"
            }
        }
    }
    // pre-push is the final gate: check-only formatting/lint plus the full test
    // suite and a coverage report before code reaches the remote.
    ["pre-push"] {
        steps {
            ["cargo-fmt-check"] {
                glob = "**/*.rs"
                // Delegates to mise so the pinned nightly (rust-nightly.txt) stays in
                // one place; rustfmt.toml enables unstable import options.
                check = "mise run format-check"
            }
            ["cargo-clippy-check"] {
                glob = "**/*.rs"
                check = "cargo clippy --all-targets -- -D warnings"
            }
            ["cargo-test"] {
                check = "cargo test"
            }
            ["coverage"] {
                check = "mise run coverage"
            }
        }
    }
}
